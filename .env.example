# --- Server-side only (Vercel serverless functions) ---
# Used by /api/research for AI product research (free tier available).
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Used by /api/research to fetch real product images.
SERPAPI_KEY=...

# --- Client-side (exposed to the browser by Vite) ---
# Mapbox PUBLIC token (pk....). Safe to ship to the client.
# Used by the location picker in Project Setup.
VITE_MAPBOX_TOKEN=pk....
